<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="366px"
    android:layout_height="484px">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_cancel"
        android:layout_width="@dimen/normal_60dp"
        android:layout_height="@dimen/normal_60dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatEditText
        android:textSize="@dimen/normal_34sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/et_input_code"
        android:background="@null"
        android:paddingTop="@dimen/normal_5dp"
        android:paddingBottom="@dimen/normal_5dp"
        android:focusable="false"
        android:layout_width="@dimen/normal_300dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/normal_120dp"
        android:layout_marginTop="@dimen/normal_80dp"
        android:layout_marginRight="@dimen/normal_120dp"
        android:maxLength="12"
        android:layout_marginHorizontal="@dimen/normal_120dp"
        android:paddingVertical="@dimen/normal_5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.wugu.doublecamera.custom.NumKeyboard
        android:id="@+id/layout_num_keyboard"
        android:paddingBottom="@dimen/normal_80dp"
        android:layout_width="280px"
        android:layout_height="320px"
        android:layout_marginTop="@dimen/normal_10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_input_code"/>
</androidx.constraintlayout.widget.ConstraintLayout>
