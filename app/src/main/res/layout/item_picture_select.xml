<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/normal_160dp"
    android:layout_marginLeft="@dimen/normal_10dp"
    android:layout_marginRight="@dimen/normal_10dp"
    android:layout_marginHorizontal="@dimen/normal_10dp">
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_gravity="center"
        android:id="@+id/iv_photo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_selected"
        android:visibility="gone"
        android:layout_width="@dimen/normal_40dp"
        android:layout_height="@dimen/normal_40dp"
        android:src="@drawable/ic_selected"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
