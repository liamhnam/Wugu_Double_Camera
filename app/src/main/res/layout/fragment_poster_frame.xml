<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.wugu.doublecamera.custom.StrokeTextView
        android:textSize="@dimen/normal_86sp"
        android:textStyle="bold"
        android:textColor="@color/countdown_color"
        android:gravity="center"
        android:id="@+id/tv_countdown"
        android:layout_width="120px"
        android:layout_height="100px"
        android:layout_x="190px"
        android:layout_y="50px"
        android:alpha="0.6"
        app:strokeColor="@color/white"
        app:strokeWidth="@dimen/normal_3dp"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_frame"
        android:layout_width="1700px"
        android:layout_height="620px"
        android:layout_x="100px"
        android:layout_y="220px"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_enter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:layout_x="1500px"
        android:layout_y="850px"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:layout_x="160px"
        android:layout_y="850px"/>
</AbsoluteLayout>
