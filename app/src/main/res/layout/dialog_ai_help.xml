<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/shape_bg_ai_help"
    android:layout_width="1080px"
    android:layout_height="720px">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_cancel"
        android:layout_width="@dimen/normal_60dp"
        android:layout_height="@dimen/normal_60dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.wugu.doublecamera.custom.StrokeTextView
        android:textSize="@dimen/normal_48sp"
        android:textStyle="bold"
        android:textColor="@color/countdown_color"
        android:gravity="center"
        android:id="@+id/tv_countdown"
        android:layout_width="wrap_content"
        android:layout_height="60px"
        android:alpha="0.6"
        android:layout_marginEnd="@dimen/normal_10dp"
        app:layout_constraintBottom_toBottomOf="@+id/btn_cancel"
        app:layout_constraintEnd_toStartOf="@+id/btn_cancel"
        app:layout_constraintTop_toTopOf="@+id/btn_cancel"
        app:strokeColor="@color/white"
        app:strokeWidth="@dimen/normal_3dp"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/normal_32sp"
        android:textColor="#ff333333"
        android:id="@+id/tv_msg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/normal_50dp"
        android:layout_marginTop="@dimen/normal_20dp"
        android:layout_marginRight="@dimen/normal_50dp"
        android:layout_marginBottom="@dimen/normal_20dp"
        android:text="@string/ai_help_detail"
        android:layout_marginHorizontal="@dimen/normal_50dp"
        android:layout_marginVertical="@dimen/normal_20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_cancel"/>
</androidx.constraintlayout.widget.ConstraintLayout>
