<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/normal_210dp"
    android:layout_marginLeft="@dimen/normal_2dp"
    android:layout_marginTop="@dimen/normal_2dp"
    android:layout_marginRight="@dimen/normal_2dp"
    android:layout_marginBottom="@dimen/normal_2dp"
    android:layout_marginHorizontal="@dimen/normal_2dp"
    android:layout_marginVertical="@dimen/normal_2dp">
    <ImageView
        android:id="@+id/iv_demo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="@dimen/normal_5dp"
        android:layout_marginTop="@dimen/normal_5dp"
        android:layout_marginRight="@dimen/normal_5dp"
        android:layout_marginHorizontal="@dimen/normal_5dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_name"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/normal_18sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/normal_2dp"
        android:lines="1"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
