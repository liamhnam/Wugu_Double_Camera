<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.wugu.doublecamera.custom.CountdownView
        android:id="@+id/layout_countdown"
        android:layout_width="@dimen/countdown_view_w"
        android:layout_height="@dimen/countdown_view_h"
        android:layout_margin="15px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_qrcode"
        android:layout_width="400px"
        android:layout_height="400px"
        android:layout_marginBottom="25px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.wugu.doublecamera.custom.PaymentSelectView
        android:id="@+id/layout_payment_select"
        android:visibility="gone"
        android:layout_width="370px"
        android:layout_height="510px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_upload_picture"
        android:paddingTop="60px"
        android:paddingBottom="15px"
        android:visibility="gone"
        android:layout_width="400px"
        android:layout_height="640px"
        android:layout_marginTop="150px"
        android:layout_marginStart="60px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.Group
        android:id="@+id/group_print_count"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:constraint_referenced_ids="iv_print_count_text,iv_sub,iv_add,tv_print_count,tv_print_price"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_print_count_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/normal_50dp"
        android:scaleType="centerInside"
        android:maxWidth="550px"
        android:maxHeight="80px"
        android:layout_marginStart="15px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rv_upload_picture"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:maxWidth="50px"
        android:maxHeight="50px"
        android:layout_marginEnd="20px"
        app:layout_constraintBottom_toBottomOf="@+id/tv_print_count"
        app:layout_constraintEnd_toStartOf="@+id/tv_print_count"
        app:layout_constraintTop_toTopOf="@+id/tv_print_count"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:maxWidth="50px"
        android:maxHeight="50px"
        android:layout_marginStart="20px"
        app:layout_constraintBottom_toBottomOf="@+id/tv_print_count"
        app:layout_constraintStart_toEndOf="@+id/tv_print_count"
        app:layout_constraintTop_toTopOf="@+id/tv_print_count"/>
    <com.wugu.doublecamera.custom.StrokeTextView
        android:textSize="@dimen/normal_36sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_print_count"
        android:layout_width="50px"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:maxHeight="150px"
        android:text="1"
        android:layout_marginStart="320px"
        android:letterSpacing="0.03"
        app:layout_constraintBottom_toBottomOf="@+id/iv_print_count_text"
        app:layout_constraintStart_toStartOf="@+id/iv_print_count_text"
        app:layout_constraintTop_toTopOf="@+id/iv_print_count_text"
        app:strokeColor="@color/white"
        app:strokeWidth="@dimen/normal_3dp"/>
    <com.wugu.doublecamera.custom.StrokeTextView
        android:textSize="@dimen/normal_28sp"
        android:textColor="@color/sign_red"
        android:id="@+id/tv_print_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/normal_10dp"
        android:maxWidth="200px"
        android:maxHeight="80px"
        android:letterSpacing="0.03"
        app:layout_constraintEnd_toEndOf="@+id/tv_print_count"
        app:layout_constraintStart_toStartOf="@+id/tv_print_count"
        app:layout_constraintTop_toBottomOf="@+id/tv_print_count"
        app:strokeColor="#ffffff"
        app:strokeWidth="3dp"/>
    <com.wugu.doublecamera.custom.PictureSplicing
        android:id="@+id/layout_splicing"
        android:visibility="gone"
        android:layout_width="900px"
        android:layout_height="900px"
        android:layout_marginTop="60px"
        android:layout_marginStart="520px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_frame_ic"
        android:paddingTop="60px"
        android:paddingBottom="15px"
        android:visibility="gone"
        android:layout_width="400px"
        android:layout_height="640px"
        android:layout_marginTop="150px"
        android:layout_marginStart="1470px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="800px"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_enter"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="820px"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="@+id/rv_frame_ic"
        app:layout_constraintStart_toStartOf="@+id/rv_frame_ic"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
