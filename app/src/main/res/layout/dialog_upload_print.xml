<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/shape_bg_select_camera"
    android:layout_width="@dimen/normal_800dp"
    android:layout_height="@dimen/normal_800dp">
    <com.wugu.doublecamera.custom.BtnBackCountdown
        android:id="@+id/layout_btn_countdown"
        android:layout_width="@dimen/normal_160dp"
        android:layout_height="@dimen/normal_100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_qrcode"
        android:layout_width="@dimen/normal_500dp"
        android:layout_height="@dimen/normal_500dp"
        android:layout_marginTop="@dimen/normal_50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_btn_countdown"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/normal_34sp"
        android:textColor="@color/black"
        android:id="@+id/tv_loading"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/iv_qrcode"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_qrcode"/>
</androidx.constraintlayout.widget.ConstraintLayout>
