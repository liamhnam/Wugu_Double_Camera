<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.wugu.doublecamera.custom.CountdownView
        android:id="@+id/layout_countdown"
        android:layout_width="@dimen/countdown_view_w"
        android:layout_height="@dimen/countdown_view_h"
        android:layout_x="15px"
        android:layout_y="15px"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:paddingLeft="30px"
        android:paddingRight="30px"
        android:layout_width="match_parent"
        android:layout_height="635px"
        android:layout_x="0px"
        android:layout_y="160px"
        android:paddingHorizontal="30px"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_print"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:layout_x="820px"
        android:layout_y="820px"/>
    <com.wugu.doublecamera.custom.PrintPaymentView
        android:id="@+id/layout_payment"
        android:visibility="gone"
        android:layout_width="420px"
        android:layout_height="510px"
        android:layout_x="750px"
        android:layout_y="250px"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_photo_qrcode"
        android:visibility="gone"
        android:layout_width="400px"
        android:layout_height="400px"
        android:layout_x="760px"
        android:layout_y="280px">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_photo_qrcode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="@dimen/normal_26sp"
            android:id="@+id/tv_upload_process"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.davemorrissey.labs.subscaleview.SubsamplingScaleImageView
        android:id="@+id/iv_detail"
        android:background="#66000000"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_close"
        android:visibility="gone"
        android:layout_width="100px"
        android:layout_height="130px"
        android:scaleType="centerInside"
        android:layout_x="1780px"
        android:layout_y="30px"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_back"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:layout_x="760px"
        android:layout_y="880px"/>
</AbsoluteLayout>
