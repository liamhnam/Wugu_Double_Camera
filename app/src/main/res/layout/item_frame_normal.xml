<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="535px"
    android:layout_height="match_parent"
    android:layout_marginLeft="@dimen/normal_15dp"
    android:layout_marginRight="@dimen/normal_15dp"
    android:layout_marginHorizontal="@dimen/normal_15dp">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_frame_example"
        android:background="#e3e3e3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="110px"
        android:layout_marginBottom="200px"
        android:scaleType="centerInside"
        android:layout_marginStart="30px"
        android:layout_marginEnd="30px"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_cut_icon"
        android:layout_width="200px"
        android:layout_height="60px"
        android:layout_marginBottom="135px"
        android:scaleType="centerInside"
        android:layout_marginStart="60px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <com.wugu.doublecamera.custom.StrokeTextView
        android:textSize="@dimen/normal_26sp"
        android:textColor="@color/black"
        android:id="@+id/tv_frame_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60px"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/sign_red"
        app:strokeWidth="@dimen/normal_1dp"/>
    <com.wugu.doublecamera.custom.StrokeTextView
        android:textSize="@dimen/normal_26sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:id="@+id/tv_frame_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="63px"
        android:layout_marginStart="110px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/white"
        app:strokeWidth="@dimen/normal_3dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
