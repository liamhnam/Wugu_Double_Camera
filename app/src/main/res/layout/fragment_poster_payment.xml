<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#66000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/view_payment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerInside"
        android:layout_x="0px"
        android:layout_y="0px"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:layout_x="865px"
        android:layout_y="850px"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_payment_method"
        android:layout_width="800px"
        android:layout_height="100px"
        android:layout_x="560px"
        android:layout_y="720px">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_payment1"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_payment2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_payment2"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_payment3"
            app:layout_constraintStart_toEndOf="@+id/iv_payment1"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_payment3"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_payment4"
            app:layout_constraintStart_toEndOf="@+id/iv_payment2"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_payment4"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_payment5"
            app:layout_constraintStart_toEndOf="@+id/iv_payment3"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_payment5"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_payment6"
            app:layout_constraintStart_toEndOf="@+id/iv_payment4"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_payment6"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_payment7"
            app:layout_constraintStart_toEndOf="@+id/iv_payment5"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_payment7"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_payment6"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/normal_30sp"
        android:gravity="center"
        android:id="@+id/tv_price"
        android:visibility="gone"
        android:layout_width="120px"
        android:layout_height="wrap_content"
        android:layout_x="1000px"
        android:layout_y="752px"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_qrcode"
        android:visibility="gone"
        android:layout_width="400px"
        android:layout_height="400px"
        android:layout_x="760px"
        android:layout_y="180px"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/normal_30sp"
        android:gravity="center"
        android:id="@+id/tv_balance"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="920px"
        android:layout_y="620px"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_code_ex_bg"
        android:visibility="gone"
        android:layout_width="366px"
        android:layout_height="484px"
        android:scaleType="centerInside"
        android:layout_x="777px"
        android:layout_y="210px"/>
    <androidx.appcompat.widget.AppCompatEditText
        android:textSize="@dimen/normal_42sp"
        android:gravity="start"
        android:id="@+id/et_code_input"
        android:background="@null"
        android:focusable="false"
        android:visibility="gone"
        android:layout_width="260px"
        android:layout_height="wrap_content"
        android:maxLength="10"
        android:layout_x="830px"
        android:layout_y="265px"/>
    <com.wugu.doublecamera.custom.NumKeyboard
        android:id="@+id/layout_keyboard"
        android:visibility="gone"
        android:layout_width="290px"
        android:layout_height="310px"
        android:layout_x="815px"
        android:layout_y="335px"/>
    <com.wugu.doublecamera.custom.StrokeTextView
        android:textSize="@dimen/normal_86sp"
        android:textStyle="bold"
        android:textColor="@color/countdown_color"
        android:gravity="center"
        android:id="@+id/tv_countdown"
        android:layout_width="120px"
        android:layout_height="100px"
        android:layout_x="1050px"
        android:layout_y="855px"
        android:alpha="0.6"
        android:letterSpacing="0.03"
        app:strokeColor="@color/white"
        app:strokeWidth="@dimen/normal_3dp"/>
</AbsoluteLayout>
