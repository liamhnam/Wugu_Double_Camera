<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_marginLeft="@dimen/normal_5dp"
    android:layout_marginRight="@dimen/normal_5dp"
    android:soundEffectsEnabled="false"
    android:layout_marginHorizontal="@dimen/normal_5dp">
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/normal_36sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/tv_theme_name"
        android:paddingLeft="@dimen/normal_30dp"
        android:paddingRight="@dimen/normal_30dp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="3dp"
        android:soundEffectsEnabled="false"
        android:layout_marginVertical="3dp"
        android:paddingHorizontal="@dimen/normal_30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
