<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:padding="15dp"
        android:layout_width="match_parent"
        android:layout_height="920px"
        android:layout_x="0px"
        android:layout_y="0px"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_theme"
        android:layout_width="match_parent"
        android:layout_height="160px"
        android:layout_x="0px"
        android:layout_y="920px"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/btn_back"
        android:padding="10px"
        android:layout_width="100px"
        android:layout_height="100px"
        android:src="@drawable/ic_close"
        android:scaleType="centerInside"
        android:layout_x="1750px"
        android:layout_y="30px"/>
    <com.wugu.doublecamera.custom.StrokeTextView
        android:textSize="@dimen/normal_46sp"
        android:textStyle="bold"
        android:textColor="@color/countdown_color"
        android:gravity="center"
        android:id="@+id/tv_countdown"
        android:layout_width="120px"
        android:layout_height="100px"
        android:layout_x="1630px"
        android:layout_y="30px"
        android:alpha="0.6"
        app:strokeColor="@color/white"
        app:strokeWidth="@dimen/normal_3dp"/>
</AbsoluteLayout>
