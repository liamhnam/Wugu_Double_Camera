<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="400px"
    android:layout_height="match_parent"
    android:layout_marginLeft="@dimen/normal_20dp"
    android:layout_marginRight="@dimen/normal_20dp"
    android:layout_marginHorizontal="@dimen/normal_20dp">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_frame"
        android:background="#e3e3e3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:maxHeight="550px"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_frame_selected"
        app:layout_constraintEnd_toEndOf="@+id/iv_frame_selected"
        app:layout_constraintStart_toStartOf="@+id/iv_frame_selected"
        app:layout_constraintTop_toTopOf="@+id/iv_frame_selected"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_frame_selected"
        android:layout_width="match_parent"
        android:layout_height="570px"
        android:scaleType="centerInside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_price_icon"
        android:layout_width="40px"
        android:layout_height="40px"
        android:layout_marginTop="8px"
        android:scaleType="centerInside"
        android:layout_marginStart="50px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_frame_selected"/>
    <com.wugu.doublecamera.custom.StrokeTextView
        android:textSize="@dimen/normal_32sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:id="@+id/tv_frame_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10px"
        app:layout_constraintBottom_toBottomOf="@+id/iv_price_icon"
        app:layout_constraintStart_toEndOf="@+id/iv_price_icon"
        app:layout_constraintTop_toTopOf="@+id/iv_price_icon"
        app:strokeColor="@color/white"
        app:strokeWidth="@dimen/normal_3dp"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/normal_22sp"
        android:textColor="@color/white"
        android:id="@+id/tv_frame_price_invalid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0.6"
        android:layout_marginStart="@dimen/normal_8dp"
        app:layout_constraintBaseline_toBaselineOf="@+id/tv_frame_price"
        app:layout_constraintStart_toEndOf="@+id/tv_frame_price"/>
</androidx.constraintlayout.widget.ConstraintLayout>
